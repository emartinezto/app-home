# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:4200

# Database (Postgres) — en producción usa DATABASE_URL (Supabase)
# DATABASE_URL=postgresql://user:pass@host:5432/postgres
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=casa_garcia
DB_PASSWORD=changeme
DB_NAME=casa_garcia
DB_CONNECTION_LIMIT=10
DB_SSL=false

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=replace-with-long-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-different-long-random-string-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Bcrypt
BCRYPT_COST=12

# Rate limit (login)
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=300000

# VAPID (genera con `npm run vapid:keys`)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@casa-garcia.local

# Cron
CRON_TIMEZONE=Europe/Madrid
CRON_ENABLED=true

# App
DEFAULT_TIMEZONE=Europe/Madrid
INVITE_CODE_TTL_HOURS=48
